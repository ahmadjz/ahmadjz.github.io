---
import type { Content } from '../../i18n/content';
import Section from '../Section.astro';

interface Props {
  content: Content;
}
const { content } = Astro.props;
const s = content.skills;
---
<Section id="skills" eyebrow={s.eyebrow} title={s.title}>
  <p slot="intro" class="mt-4 text-lg leading-relaxed text-muted" data-reveal>{s.intro}</p>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
    {s.groups.map((group) => (
      <div data-reveal class="card p-5 transition-colors hover:border-line-strong">
        <h3 class="mb-4 flex items-center gap-2 text-sm font-semibold text-ink">
          <span class="h-3.5 w-0.5 rounded-full bg-gradient-to-b from-accent to-accent-2"></span>
          {group.label}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.items.map((item) => (
            <li class="rounded-lg border border-line bg-elevated/50 px-2.5 py-1 font-mono text-sm text-muted transition-colors hover:border-accent-soft/50 hover:text-ink">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Section>
