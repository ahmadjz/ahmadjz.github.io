---
import Base from '../layouts/Base.astro';
import { getContent } from '../i18n';
const content = getContent('en');
const base = import.meta.env.BASE_URL;
---
<Base lang="en" content={content}>
  <main id="main" class="grid min-h-[100svh] place-items-center px-6 text-center">
    <div>
      <p class="eyebrow">404</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight">Page not found</h1>
      <p class="mt-3 text-muted">The page you are looking for does not exist.</p>
      <a href={base} class="mt-7 inline-flex rounded-full bg-ink px-6 py-3 font-medium text-bg transition-colors hover:bg-white">
        Back home
      </a>
    </div>
  </main>
</Base>
