---
import Icon from './Icon.astro';
interface Props {
  labelOn: string;
  labelOff: string;
}
const { labelOn } = Astro.props;
---
<button
  type="button"
  data-motion-toggle
  aria-pressed="false"
  aria-label={labelOn}
  title={labelOn}
  class="inline-grid size-9 place-items-center rounded-lg border border-line text-muted transition-colors hover:border-line-strong hover:text-ink focus-visible:text-ink"
>
  <Icon name="motion" size={18} />
</button>
