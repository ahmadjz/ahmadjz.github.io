---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '@fontsource/ibm-plex-sans-arabic/400.css';
import '@fontsource/ibm-plex-sans-arabic/600.css';
import '@fontsource/ibm-plex-sans-arabic/700.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { Content } from '../i18n/content';
import type { Locale } from '../data/site';
import { SITE_URL, IDENTITY, SOCIALS, PHOTO } from '../data/site';
import { dir } from '../data/site';

interface Props {
  lang: Locale;
  content: Content;
}
const { lang, content } = Astro.props;
const base = import.meta.env.BASE_URL;
const direction = dir(lang);

const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const enHref = new URL(base, SITE_URL).href;
const arHref = new URL(`${base}ar/`.replace(/\/{2,}/g, '/'), SITE_URL).href;
const ogImage = new URL(`${base}og.png`.replace(/\/{2,}/g, '/'), SITE_URL).href;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: IDENTITY.name,
  alternateName: IDENTITY.nameAr,
  url: SITE_URL + base,
  image: new URL(`${base}${PHOTO}`.replace(/\/{2,}/g, '/'), SITE_URL).href,
  jobTitle: 'Full-Stack Software Engineer',
  email: `mailto:${IDENTITY.email}`,
  address: { '@type': 'PostalAddress', addressLocality: 'Damascus', addressCountry: 'SY' },
  knowsLanguage: ['ar', 'en'],
  sameAs: [SOCIALS.github, SOCIALS.linkedin],
};
---
<!doctype html>
<html lang={lang} dir={direction}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="ar" href={arHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <meta name="theme-color" content="#09090b" />
    <meta name="color-scheme" content="dark" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content={IDENTITY.name} />
    <meta property="og:title" content={content.meta.title} />
    <meta property="og:description" content={content.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_SY' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={content.meta.ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.title} />
    <meta name="twitter:description" content={content.meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:start-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-elevated focus:px-4 focus:py-2 focus:text-ink focus:ring-2 focus:ring-accent-soft">
      {content.a11y.skip}
    </a>

    <slot />

    <script>
      import { init } from '../scripts/main';
      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
