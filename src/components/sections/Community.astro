---
import type { Content } from '../../i18n/content';
import Section from '../Section.astro';

interface Props {
  content: Content;
}
const { content } = Astro.props;
const c = content.community;
---
<Section id="community" eyebrow={c.eyebrow} title={c.title}>
  <div class="grid gap-6 lg:grid-cols-3" data-reveal-group>
    {c.items.map((item) => (
      <div data-reveal class="card p-6 transition-colors hover:border-line-strong">
        <div class="flex items-baseline justify-between gap-3">
          <h3 class="font-semibold text-ink">{item.org}</h3>
          <span class="font-mono text-xs text-faint">{item.dates}</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted">{item.detail}</p>
      </div>
    ))}
  </div>

  <div
    class="card mt-6 p-6 sm:p-8"
    data-reveal
  >
    <p class="eyebrow">{c.educationTitle}</p>
    <div class="mt-3 flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <h3 class="text-xl font-semibold text-ink">{c.school}</h3>
      <span class="font-mono text-xs text-faint">{c.dates}</span>
    </div>
    <p class="mt-1 text-muted">{c.degree}</p>
    <p class="mt-2 text-sm text-muted">{c.detail}</p>

    <dl class="mt-6 grid gap-4 sm:grid-cols-2">
      {c.projects.map((p) => (
        <div class="rounded-xl border border-line bg-elevated/40 p-4">
          <dt class="font-mono text-xs uppercase tracking-wider text-accent-soft">{p.name}</dt>
          <dd class="mt-1.5 text-sm leading-relaxed text-muted">{p.desc}</dd>
        </div>
      ))}
    </dl>
  </div>
</Section>
