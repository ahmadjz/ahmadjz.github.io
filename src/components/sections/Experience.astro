---
import type { Content } from '../../i18n/content';
import Section from '../Section.astro';
import Icon from '../Icon.astro';

interface Props {
  content: Content;
}
const { content } = Astro.props;
const e = content.experience;
---
<Section id="experience" eyebrow={e.eyebrow} title={e.title}>
  <p slot="intro" class="mt-4 text-lg leading-relaxed text-muted" data-reveal>{e.intro}</p>

  <ol class="relative max-w-3xl" data-reveal-group>
    {e.roles.map((role) => (
      <li data-reveal class="relative border-s border-line ps-8 pb-10 last:border-transparent last:pb-0">
        <span
          class="absolute start-[-5px] top-1.5 size-2.5 rounded-full bg-accent ring-4 ring-bg"
          aria-hidden="true"
        ></span>

        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
          <h3 class="text-lg font-semibold text-ink">
            {role.url ? (
              <a
                href={role.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 decoration-line-strong underline-offset-4 hover:underline"
              >
                {role.company}
                <Icon name="external" size={13} class="text-faint" />
              </a>
            ) : (
              role.company
            )}
          </h3>
          <span class="font-mono text-xs text-faint">{role.dates}</span>
        </div>

        <p class="mt-0.5 text-sm text-muted">
          {role.role} <span class="text-faint">· {role.type}</span>
        </p>

        <ul class="mt-3 space-y-1.5">
          {role.bullets.map((b) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-muted">
              <span class="mt-2 size-1 shrink-0 rounded-full bg-accent-soft/70" aria-hidden="true"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        {role.tags && (
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {role.tags.map((t) => (
              <li class="rounded border border-line/80 px-1.5 py-0.5 font-mono text-[0.68rem] text-faint">{t}</li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ol>
</Section>
