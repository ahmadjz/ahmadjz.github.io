---
import type { Content, Project } from '../i18n/content';
import Icon from './Icon.astro';

interface Props {
  project: Project;
  content: Content;
  compact?: boolean;
}
const { project, content, compact = false } = Astro.props;
const w = content.work;

const links = [
  project.links.live && { href: project.links.live, label: w.viewLive, icon: 'external', primary: true },
  project.links.play && { href: project.links.play, label: w.viewApp, icon: 'play', primary: true },
  project.links.repo && { href: project.links.repo, label: w.viewCode, icon: 'code', primary: false },
  project.links.company && { href: project.links.company, label: w.viewCompany, icon: 'external', primary: false },
].filter(Boolean) as { href: string; label: string; icon: string; primary: boolean }[];

const hasExternal = links.length > 0;
const isBuilding = project.status === 'building';
---
<article
  data-reveal
  class="card group flex h-full flex-col p-6 transition-colors hover:border-line-strong sm:p-7"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-xl font-semibold tracking-tight text-ink">{project.name}</h3>
      <p class="mt-0.5 font-mono text-xs text-faint">{project.role} · {project.year}</p>
    </div>
    {isBuilding ? (
      <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-accent-2/40 px-2.5 py-1 text-xs text-accent-2">
        <span class="size-1.5 rounded-full bg-accent-2"></span>
        {w.buildingLabel}
      </span>
    ) : !hasExternal ? (
      <span class="shrink-0 rounded-full border border-line px-2.5 py-1 text-xs text-faint">{w.privateNote}</span>
    ) : null}
  </div>

  <p class="mt-4 font-medium text-ink/90">{project.tagline}</p>

  {!compact && (
    <p class="mt-3 text-sm leading-relaxed text-muted">{project.approach}</p>
  )}
  <p class="mt-2 text-sm leading-relaxed text-muted">{project.impact}</p>

  {project.metrics && project.metrics.length > 0 && (
    <dl class="mt-5 grid grid-cols-3 gap-3 border-y border-line/70 py-4">
      {project.metrics.map((m) => (
        <div>
          <dd class="font-mono text-2xl font-semibold text-gradient tabular-nums">
            <span data-countup={m.value}>0</span>{m.suffix}
          </dd>
          <dt class="mt-0.5 text-xs text-faint">{m.label}</dt>
        </div>
      ))}
    </dl>
  )}

  <ul class="mt-5 flex flex-wrap gap-1.5">
    {project.tech.map((t) => (
      <li class="rounded-md border border-line bg-elevated/60 px-2 py-0.5 font-mono text-[0.7rem] text-muted">{t}</li>
    ))}
  </ul>

  {hasExternal && (
    <div class="mt-6 flex flex-wrap gap-2 pt-1">
      {links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors',
            l.primary
              ? 'bg-ink text-bg hover:bg-white'
              : 'border border-line-strong text-ink hover:bg-elevated',
          ]}
        >
          <Icon name={l.icon} size={14} />
          {l.label}
        </a>
      ))}
    </div>
  )}
</article>
